# Configuración del Entorno de Desarrollo - SIGEX (Plantilla de Ejemplo)
# Copia este archivo como '.env' y completa con tus datos locales.

FLASK_APP=run.py
FLASK_DEBUG=1

# Clave secreta para sesiones y protección CSRF (Flask-WTF)
# Puedes generar una clave aleatoria en la terminal con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_super_segura_aqui

# Configuración de base de datos PostgreSQL local
DB_USER=tu_usuario_postgres
DB_PASSWORD=tu_contraseña_postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sigex_db

# Configuración del Servidor de Correos (SMTP - Ejemplo con Gmail)
# Para usar Gmail, activa la verificación en 2 pasos de Google y genera una "Contraseña de aplicación".
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=tu_correo_institucional@gmail.com
MAIL_PASSWORD=tu_clave_de_aplicacion_google_de_16_letras
MAIL_DEFAULT_SENDER=SIGEX <tu_correo_institucional@gmail.com>
